# FTO Backend — environment variables
# Copy to .env and fill in real values

# Telegram bot token from @BotFather (REQUIRED)
TELEGRAM_BOT_TOKEN=

# Chat ID where to send messages (REQUIRED)
# To get your chat ID: send any message to your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates — chat.id will be in the response
TELEGRAM_CHAT_ID=

# Allowed CORS origin (your GitHub Pages URL)
CORS_ORIGIN=https://alfat81.github.io

# Server port (Render sets this automatically; for local dev use 10000)
PORT=10000
