# FTO Backend — environment variables for EMAIL (Mail.ru SMTP)
# Copy to .env and fill in real values

# ━━ SMTP: Mail.ru ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Для авторизации нужен "пароль приложения" (НЕ основной пароль от ящика).
# Создаётся в настройках: https://my.mail.ru/cgi-bin/security?allow_external_apps=1

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=alfat@list.ru
SMTP_PASS=

# ━━ Куда отправлять уведомления ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# На этот адрес будут приходить все заявки с сайта
EMAIL_TO=alfat@list.ru

# Имя отправителя в письме
EMAIL_FROM=Сайт ФТО

# ━━ CORS ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CORS_ORIGIN=https://alfat81.github.io

# ━━ Порт ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Render задаёт автоматически; для локального запуска используйте 10000
PORT=10000
